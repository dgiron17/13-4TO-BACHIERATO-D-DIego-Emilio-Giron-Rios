//Verificar si un numero es positivo
Algoritmo Numpositivos_negativos
	
	Escribir  "===Numeros positivos y negativos==="
	Definir num Como Entero
	Escribir "Dame un numero entero"
	
	Leer num
	
	Si num >= 0 Entonces
		Escribir "es un numero positivo"
	SiNo
		Escribir "es un numero negativo"
	Fin Si
	
FinAlgoritmo
